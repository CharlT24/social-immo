# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# --- Base de donnees (choisir UNE option) ---

# Option 1 : DATABASE_URL (PostgreSQL Supabase, ou MySQL)
# PostgreSQL : postgres://user:password@host:5432/dbname
# MySQL      : mysql://user:password@host:3306/dbname
# DATABASE_URL=mysql://user:password@mysql-host.o2switch.net:3306/socialimmo

# Option 2 : MySQL o2switch (variables separees)
# MYSQL_HOST=mysql-host.o2switch.net
# MYSQL_DATABASE=socialimmo
# MYSQL_USER=your_user
# MYSQL_PASSWORD=your_password
# MYSQL_PORT=3306

# Option 3 : SQLite (defaut, aucune variable necessaire)

# --- Social Immo - Flux XML ---
SOCIALIMMO_AGENCE_ID=OI123
